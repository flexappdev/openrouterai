# Supabase — single-user gate
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ADMIN_EMAIL=mat@matsiems.com

# OpenRouter — chat proxy
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4-6

# Mongo — request logs (soft-fail)
MONGODB_URI=
MONGODB_DB=OPENROUTERAI

# GA4
NEXT_PUBLIC_GA_ID=

# Stripe — billing (optional; /api/billing/* returns 503 without these)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional — origin used for OpenRouter attribution + Stripe redirects
NEXT_PUBLIC_APP_URL=
